# RF Rabbit Configuration
# All frequencies in Hz, durations in seconds

# --- Global ---
# Cycle through signal profiles with random pauses between them
CYCLE_MIN_PAUSE=5
CYCLE_MAX_PAUSE=30

# HackRF TX gain (0-47 dB)
HACKRF_TX_GAIN=47
HACKRF_IF_GAIN=47
HACKRF_SAMPLE_RATE=2000000

# --- ICOM-like Profile ---
# Simulates narrowband FM voice comms on 2m band
ICOM_ENABLED=true
ICOM_FREQ=146520000
ICOM_BANDWIDTH=12500
ICOM_TX_DURATION_MIN=2
ICOM_TX_DURATION_MAX=8
ICOM_BURSTS=3

# --- Walkie-talkie Profile ---
# Simulates FRS/GMRS-style UHF FM
WALKIE_ENABLED=true
WALKIE_FREQ=462562500
WALKIE_BANDWIDTH=12500
WALKIE_TX_DURATION_MIN=1
WALKIE_TX_DURATION_MAX=5
WALKIE_BURSTS=4

# --- LoRa-like Profile ---
# Simulates chirp spread spectrum on 915MHz ISM
LORA_ENABLED=true
LORA_FREQ=915000000
LORA_BANDWIDTH=125000
LORA_CHIRP_DURATION=0.5
LORA_BURSTS=6

# --- WiFi Traffic ---
WIFI_ENABLED=true
WIFI_INTERFACE=wlan0
BERYL_IP=192.168.8.1
WIFI_SSID=0332
WIFI_PASSWORD=specialforces
# Traffic patterns: ping, iperf, curl, mixed
WIFI_PATTERN=mixed
WIFI_DURATION=30
